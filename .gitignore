# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# firebase
.firebase/
firebase-debug.log*
functions/lib/
functions/node_modules/
functions/.next/

# IDE
.idea/
.vscode/

# tools / plugins
.omc/
.playwright-mcp/
.agent/

# screenshots / captures (dev artifacts)
*.png
*.jpeg
*.html
!public/**/*.png
!public/**/*.jpeg
!public/**/*.jpg
!app/**/*.html
/mockups/
/mockups-refined/

# dev docs / reports
/docs/
!/docs/specs/

# sensitive
ENV_BACKUP.md

# one-time scripts with hardcoded config
scripts/run-migration.mjs
functions/scripts/bootstrap-cli-auth.js

# Windows reserved filenames
nul
